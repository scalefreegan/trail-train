# Dependencies
node_modules/

# Build output
web/dist/
web/.vite/

# Personal data snapshots — generated locally by `npm run sync:*`.
# These contain Strava activity history, Oura sleep/HRV/RHR/tags, and the
# agent's per-snapshot readout. Do NOT commit to a public repo.
web/public/strava.json
web/public/oura.json
web/public/coach.json
web/public/state.json

# Athlete profile (name, location, local trails). The committed file is the
# example with generic placeholders; copy it to profile.json and personalize.
config/profile.json

# Defense-in-depth: never let a stray in-repo backup folder leak snapshots.
backups/
trail-train-backups/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Env files
.env
.env.local
.env.*.local
